<!-- 
=======================================================================
  Wazuh Custom Detection Rules — SOC Monitoring & Alert System
  Author  : Vivek Katkade
  Role    : SOC Analyst
  File    : /var/ossec/etc/rules/local_rules.xml

  HOW TO APPLY:
    1. Copy this file to /var/ossec/etc/rules/local_rules.xml
    2. Run: sudo systemctl restart wazuh-manager
    3. Test: sudo /var/ossec/bin/ossec-logtest

  RULE LEVEL GUIDE:
    0  - Ignored
    3  - Successful/authorised events
    5  - User generated errors
    7  - Medium importance events
    10 - High importance events
    12 - Critical — requires immediate action
    15 - Maximum severity
=======================================================================
 -->
<group name="vivek_soc_rules">
<!--  ══════════════════════════════════════════════════
       CATEGORY 1 — BRUTE FORCE & AUTHENTICATION ATTACKS
       ══════════════════════════════════════════════════  -->
<!--  SSH Brute Force — 5 failed logins in 60 seconds  -->
<rule id="100001" level="10" frequency="5" timeframe="60">
<if_matched_sid>5716</if_matched_sid>
<description>BRUTE FORCE: 5+ failed SSH logins in 60 seconds from same source</description>
<group>authentication_failures,brute_force,attack</group>
<mitre>
<id>T1110</id>
</mitre>
</rule>
<!--  SSH Brute Force — Severe: 20 failed logins in 60 seconds  -->
<rule id="100002" level="12" frequency="20" timeframe="60">
<if_matched_sid>5716</if_matched_sid>
<description>CRITICAL BRUTE FORCE: 20+ failed SSH logins — Active attack in progress</description>
<group>authentication_failures,brute_force,attack,critical</group>
<mitre>
<id>T1110</id>
</mitre>
</rule>
<!--  Successful SSH login after multiple failures (possible compromise)  -->
<rule id="100003" level="12">
<if_matched_sid>100001</if_matched_sid>
<if_sid>5715</if_sid>
<description>CRITICAL: Successful SSH login AFTER brute force — possible compromise</description>
<group>authentication_success,brute_force,possible_compromise</group>
<mitre>
<id>T1110</id>
<id>T1078</id>
</mitre>
</rule>
<!--  Failed RDP login attempt (Windows)  -->
<rule id="100004" level="8" frequency="3" timeframe="30">
<if_matched_sid>60122</if_matched_sid>
<description>BRUTE FORCE: Multiple failed RDP login attempts on Windows</description>
<group>authentication_failures,brute_force,windows</group>
<mitre>
<id>T1110</id>
</mitre>
</rule>
<!--  ══════════════════════════════════════════════════
       CATEGORY 2 — PRIVILEGE ESCALATION
       ══════════════════════════════════════════════════  -->
<!--  Root login success  -->
<rule id="100010" level="12">
<if_sid>5501</if_sid>
<user>root</user>
<description>CRITICAL: Direct root login detected — investigate immediately</description>
<group>authentication_success,privilege_escalation</group>
<mitre>
<id>T1078</id>
</mitre>
</rule>
<!--  Sudo usage detected  -->
<rule id="100011" level="7">
<if_sid>5402</if_sid>
<description>WARNING: Sudo command executed by non-root user</description>
<group>privilege_escalation,sudo</group>
<mitre>
<id>T1548.003</id>
</mitre>
</rule>
<!--  Sudo failure — wrong password  -->
<rule id="100012" level="9" frequency="3" timeframe="60">
<if_matched_sid>5403</if_matched_sid>
<description>ALERT: Multiple failed sudo attempts — possible privilege escalation</description>
<group>privilege_escalation,sudo,brute_force</group>
<mitre>
<id>T1548.003</id>
</mitre>
</rule>
<!--  ══════════════════════════════════════════════════
       CATEGORY 3 — ACCOUNT & USER CHANGES
       ══════════════════════════════════════════════════  -->
<!--  New user account created  -->
<rule id="100020" level="8">
<if_sid>5902</if_sid>
<description>WARNING: New user account created — verify if authorised</description>
<group>account_changes,useradd</group>
<mitre>
<id>T1136</id>
</mitre>
</rule>
<!--  User added to sudoers / admin group  -->
<rule id="100021" level="10">
<if_sid>5903</if_sid>
<match>sudo|wheel|admin</match>
<description>HIGH: User added to privileged group (sudo/wheel/admin)</description>
<group>account_changes,privilege_escalation</group>
<mitre>
<id>T1136</id>
<id>T1078</id>
</mitre>
</rule>
<!--  User deleted  -->
<rule id="100022" level="8">
<if_sid>5904</if_sid>
<description>WARNING: User account deleted from system</description>
<group>account_changes,userdel</group>
<mitre>
<id>T1531</id>
</mitre>
</rule>
<!--  Password change  -->
<rule id="100023" level="7">
<if_sid>5905</if_sid>
<description>INFO: User password changed — verify if authorised</description>
<group>account_changes,passwd</group>
</rule>
<!--  ══════════════════════════════════════════════════
       CATEGORY 4 — NETWORK RECONNAISSANCE & SCANNING
       ══════════════════════════════════════════════════  -->
<!--  Port scan detected  -->
<rule id="100030" level="10">
<match>nmap|port scan|SYN scan|XMAS scan|FIN scan|NULL scan</match>
<description>ALERT: Network port scan activity detected</description>
<group>recon,network_scan,attack</group>
<mitre>
<id>T1046</id>
</mitre>
</rule>
<!--  Ping sweep / ICMP flood  -->
<rule id="100031" level="7">
<match>ICMP flood|ping sweep|icmp_seq</match>
<description>WARNING: Possible ping sweep or ICMP flood detected</description>
<group>recon,network_scan</group>
<mitre>
<id>T1018</id>
</mitre>
</rule>
<!--  ARP scan  -->
<rule id="100032" level="7">
<match>arp-scan|ARP request|arp scan</match>
<description>WARNING: ARP scan detected — possible network enumeration</description>
<group>recon,network_scan</group>
<mitre>
<id>T1018</id>
</mitre>
</rule>
<!--  ══════════════════════════════════════════════════
       CATEGORY 5 — MALWARE & SUSPICIOUS PROCESSES
       ══════════════════════════════════════════════════  -->
<!--  Suspicious process execution  -->
<rule id="100040" level="10">
<match>netcat|nc -e|/bin/sh|/bin/bash -i|reverse shell</match>
<description>CRITICAL: Possible reverse shell or netcat execution detected</description>
<group>malware,reverse_shell,execution</group>
<mitre>
<id>T1059</id>
<id>T1071</id>
</mitre>
</rule>
<!--  Base64 encoded command (often used in malware)  -->
<rule id="100041" level="9">
<match>base64 -d|base64 --decode|echo.*|base64</match>
<description>WARNING: Base64 decode command detected — possible obfuscation</description>
<group>malware,obfuscation,execution</group>
<mitre>
<id>T1027</id>
</mitre>
</rule>
<!--  Wget/Curl downloading executable  -->
<rule id="100042" level="10">
<match>wget.*\.sh|curl.*\.sh|wget.*\.py|curl.*\.py|wget.*\.exe</match>
<description>HIGH: Remote script/executable download detected via wget/curl</description>
<group>malware,download,execution</group>
<mitre>
<id>T1105</id>
</mitre>
</rule>
<!--  ══════════════════════════════════════════════════
       CATEGORY 6 — FILE INTEGRITY & SYSTEM CHANGES
       ══════════════════════════════════════════════════  -->
<!--  Critical system file modified  -->
<rule id="100050" level="12">
<if_sid>550</if_sid>
<match>/etc/passwd|/etc/shadow|/etc/sudoers|/etc/ssh/sshd_config</match>
<description>CRITICAL: Sensitive system file modified — possible tampering</description>
<group>file_integrity,system_change,critical</group>
<mitre>
<id>T1098</id>
<id>T1222</id>
</mitre>
</rule>
<!--  SSH authorized_keys modified  -->
<rule id="100051" level="12">
<if_sid>550</if_sid>
<match>authorized_keys</match>
<description>CRITICAL: SSH authorized_keys file modified — possible backdoor</description>
<group>file_integrity,persistence,backdoor</group>
<mitre>
<id>T1098.004</id>
</mitre>
</rule>
<!--  Crontab modified (persistence)  -->
<rule id="100052" level="10">
<if_sid>550</if_sid>
<match>/etc/cron|/var/spool/cron</match>
<description>HIGH: Crontab modified — possible persistence mechanism</description>
<group>file_integrity,persistence</group>
<mitre>
<id>T1053.005</id>
</mitre>
</rule>
<!--  ══════════════════════════════════════════════════
       CATEGORY 7 — WINDOWS SPECIFIC
       ══════════════════════════════════════════════════  -->
<!--  Windows: New service created  -->
<rule id="100060" level="9">
<if_sid>7040</if_sid>
<description>HIGH: New Windows service created — verify if authorised</description>
<group>windows,persistence,service_created</group>
<mitre>
<id>T1543.003</id>
</mitre>
</rule>
<!--  Windows: Security log cleared  -->
<rule id="100061" level="14">
<if_sid>63103</if_sid>
<description>CRITICAL: Windows Security Event Log cleared — anti-forensics suspected</description>
<group>windows,log_cleared,anti_forensics,critical</group>
<mitre>
<id>T1070.001</id>
</mitre>
</rule>
<!--  Windows: Mimikatz or credential dumping keywords  -->
<rule id="100062" level="15">
<match>mimikatz|sekurlsa|lsadump|hashdump|credential dump</match>
<description>CRITICAL: Credential dumping tool detected — immediate response required</description>
<group>windows,credential_access,critical</group>
<mitre>
<id>T1003</id>
</mitre>
</rule>
<!--  Windows: New local admin account  -->
<rule id="100063" level="12">
<if_sid>60106</if_sid>
<description>CRITICAL: New local administrator account created on Windows</description>
<group>windows,account_changes,privilege_escalation</group>
<mitre>
<id>T1136.001</id>
</mitre>
</rule>
<!--  ══════════════════════════════════════════════════
       CATEGORY 8 — FIREWALL & NETWORK ANOMALIES
       ══════════════════════════════════════════════════  -->
<!--  Firewall dropped connection spike  -->
<rule id="100070" level="8" frequency="20" timeframe="60">
<match>DROPPED|REJECT|firewall block</match>
<description>WARNING: Spike in firewall blocked connections — possible scan/attack</description>
<group>firewall,network_anomaly</group>
<mitre>
<id>T1046</id>
</mitre>
</rule>
<!--  Connection to known malicious port  -->
<rule id="100071" level="10">
<match>dport=4444|dport=1337|dport=31337|dport=6666|dport=9999</match>
<description>HIGH: Connection to suspicious/commonly malicious port detected</description>
<group>network_anomaly,c2,malware</group>
<mitre>
<id>T1071</id>
</mitre>
</rule>
</group>